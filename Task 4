#include "mbed.h"


// rate= 200ms
#define BLINKING_RATE     200ms



// Initialise the digital pin LED1 as an output
 DigitalOut led(LED1);
 DigitalOut led2(LED2);
 DigitalOut led3(LED3);

int main(){

    for(int i=0;i<5; i++){
        led=1;
        led2=1;
        led3=1;
        ThisThread::sleep_for(BLINKING_RATE); //On time

        led=0;
        led2=0;
        led3=0;
        ThisThread::sleep_for(BLINKING_RATE);// off time
    }

while(true){

led=1;
led2=0;
led3=0;

ThisThread::sleep_for(osWaitForever); // to stay in the state forever

}

}
